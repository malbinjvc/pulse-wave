# Database
DATABASE_URL=postgres://pulsewave:pulsewave@localhost:5432/pulsewave

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-must-be-at-least-32-characters

# OpenAI (for anomaly detection)
OPENAI_API_KEY=sk-your-openai-key-here

# Server
HOST=127.0.0.1
PORT=8080

# Logging
RUST_LOG=pulse_wave_api=debug,tower_http=debug

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60
