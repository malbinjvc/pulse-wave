# Database
POSTGRES_USER=pulsewave
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=pulsewave
DATABASE_URL=postgres://pulsewave:your-strong-password-here@localhost:5432/pulsewave

# Redis
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://:your-redis-password-here@localhost:6379

# JWT (REQUIRED: minimum 32 characters, use a random string)
JWT_SECRET=replace-with-random-secret-at-least-32-characters

# OpenAI (optional, for anomaly detection)
OPENAI_API_KEY=

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:4200

# Server
HOST=127.0.0.1
PORT=8080

# Logging
RUST_LOG=pulse_wave_api=debug,tower_http=debug

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60
